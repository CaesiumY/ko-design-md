{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Vite Dev Server (TanStack Start)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "port": 3000
    },
    {
      "name": "Vite Preview Server",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["preview"],
      "port": 4173
    },
    {
      "name": "Vite Dev Server (Alt Port)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["exec", "vite", "dev", "--port", "3100"],
      "port": 3100
    },
    {
      "name": "Static Public Preview",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dlx", "serve", "public", "--listen", "3010", "--no-clipboard"],
      "port": 3010
    }
  ]
}
