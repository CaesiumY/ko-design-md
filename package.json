{
  "name": "ko-design-md",
  "version": "0.1.0",
  "description": "한국 브랜드 디자인 시스템을 Stitch v0.1 마크다운으로 정리한 오픈 카탈로그 — Open catalog of Korean design systems in structured markdown.",
  "license": "MIT",
  "author": {
    "name": "ChangSik Yoon",
    "url": "https://github.com/CaesiumY"
  },
  "homepage": "https://github.com/CaesiumY/ko-design-md#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/CaesiumY/ko-design-md.git"
  },
  "bugs": {
    "url": "https://github.com/CaesiumY/ko-design-md/issues"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "korean",
    "catalog",
    "stitch",
    "tanstack-start",
    "claude-code"
  ],
  "type": "module",
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build:favicons": "tsx scripts/build-favicons.ts",
    "build:og": "tsx scripts/build-og.ts",
    "build": "npm run build:og && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-router": "^1.170.4",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.0",
    "@tanstack/react-start": "^1.168.6",
    "@tanstack/router-plugin": "^1.168.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "jotai": "^2.20.0",
    "lucide-react": "^1.14.0",
    "nitro": "latest",
    "pretendard": "^1.3.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.7.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "^0.7.0",
    "@tanstack/eslint-config": "^0.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "10.4.0",
    "jsdom": "^29.1.1",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "tsx": "^4.22.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.13",
    "vitest": "^3.2.4",
    "web-vitals": "^5.1.0"
  }
}
